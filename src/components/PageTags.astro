---
// src/components/PageTags.astro
// Display tags for individual pages

const tags = (Astro.props.tags || [])
  .map((t: string) => t.trim())
  .filter((t: string) => t.length > 0);
---

{tags.length > 0 ? (
  <nav aria-label="Page tags" class="page-tags mt-6 flex flex-wrap gap-2">
    {tags.map((tag: string) => {
      const slug = encodeURIComponent(tag).toLowerCase().replace(/%20/g, '-');
      return (
        <a
          href={`/tags/#tag-${slug}`}
          aria-label={`View all pages with tag ${tag}`}
          class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-stone-100 dark:bg-stone-800 text-stone-800 dark:text-stone-300 hover:bg-primary/10 hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none dark:focus-visible:ring-offset-stone-900 focus-visible:ring-offset-2"
        >
          #{tag}
        </a>
      );
    })}
  </nav>
) : null}