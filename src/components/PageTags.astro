---
// src/components/PageTags.astro
// Display tags for individual pages

const slugify = (tag: string) => encodeURIComponent(tag).toLowerCase().replace(/%20/g, '-');
---

{Astro.props.tags && Astro.props.tags.length > 0 ? (
  <nav aria-label="Page tags" class="page-tags mt-6 flex flex-wrap gap-2">
    {Astro.props.tags.map(tag => (
      <a 
        href={`/tags/#tag-${slugify(tag)}`}
        aria-label={`Tag: ${tag}`}
        class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-stone-100 dark:bg-stone-800 text-stone-800 dark:text-stone-300 hover:bg-primary/10 hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 dark:focus-visible:ring-offset-stone-900 transition-colors"
      >
        #{tag}
      </a>
    ))}
  </nav>
) : null}