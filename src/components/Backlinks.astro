---
// src/components/Backlinks.astro
// Backlinks display component - minimal and visually consistent with the theme
import backlinksData from '../data/backlinks.json';

interface Props {
  slug?: string;
}

const { slug = '' } = Astro.props;

// Normalize slug - try both with and without /index
// URL /stream/ -> slug "stream" but backlinks are stored as "stream/index"
let pageBacklinks = backlinksData[slug] || [];

// Also try with /index suffix for root pages
if (pageBacklinks.length === 0 && !slug.endsWith('/index')) {
  pageBacklinks = backlinksData[`${slug}/index`] || [];
}

// Format slug to readable title
function formatTitle(linkSlug: string): string {
  const parts = linkSlug.split('/');
  const lastPart = parts[parts.length - 1];
  return lastPart
    .replace(/-/g, ' ')
    .replace(/\b\w/g, c => c.toUpperCase());
}

// Get category from slug
function getCategory(linkSlug: string): string {
  const parts = linkSlug.split('/');
  if (parts.length > 1) {
    return parts[0];
  }
  return '';
}
---

{pageBacklinks.length > 0 ? (
    <aside class="backlinks-section" aria-labelledby="backlinks-heading">
      <h3 id="backlinks-heading" class="backlinks-heading">Links to this page</h3>
      <ul class="backlinks-list">
        {pageBacklinks.map((link: string) => {
          const category = getCategory(link);
          const title = formatTitle(link);
          return (
          <li class="backlink-item">
            <a
              href={`/${link}`}
              class="backlink-link"
              aria-label={`Link to ${title}${category ? `, in ${category}` : ''}`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="backlink-icon" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              {category && <span class="backlink-category">{category}</span>}
              <span class="backlink-title">{title}</span>
            </a>
          </li>
          );
        })}
      </ul>
    </aside>
) : null}

<style>
  .backlinks-section {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--sl-color-gray-6);
  }

  .backlinks-heading {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-4);
    margin-bottom: 1rem;
  }

  .backlinks-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .backlink-item {
    margin: 0;
  }

  .backlink-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    background: var(--sl-color-gray-7);
    border: 1px solid var(--sl-color-gray-6);
    border-radius: 0.375rem;
    font-size: 0.875rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition: all 0.15s ease;
    /* Ensure interactive elements have sufficient touch target size (even if visually smaller) */
    min-height: 2.25rem;
  }

  .backlink-link:hover {
    background: var(--sl-color-accent-low);
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
  }

  /* Focus styles for accessibility */
  .backlink-link:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
    background: var(--sl-color-accent-low);
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
  }

  /* Icon styles */
  .backlink-icon {
    width: 0.875rem;
    height: 0.875rem;
    opacity: 0.7;
    transition: transform 0.2s ease, opacity 0.2s ease;
    flex-shrink: 0;
  }

  .backlink-link:hover .backlink-icon,
  .backlink-link:focus-visible .backlink-icon {
    transform: translateX(2px);
    opacity: 1;
  }

  .backlink-category {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: capitalize;
    color: var(--sl-color-gray-4);
  }

  .backlink-link:hover .backlink-category,
  .backlink-link:focus-visible .backlink-category {
    color: var(--sl-color-accent);
  }

  .backlink-title {
    font-weight: 500;
  }
</style>
